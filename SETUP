"""
Setup configuration for YouTube Chatbot
"""

from setuptools import setup, find_packages

with open("README.md", "r", encoding="utf-8") as fh:
    long_description = fh.read()

with open("requirements.txt", "r", encoding="utf-8") as fh:
    requirements = [line.strip() for line in fh if line.strip() and not line.startswith("#")]

setup(
    name="youtube-chatbot",
    version="1.0.0",
    author="Your Name",
    author_email="your.email@example.com",
    description="An intelligent chatbot that answers questions about YouTube videos using LangChain and OpenAI",
    long_description=long_description,
    long_description_content_type="text/markdown",
    url="https://github.com/yourusername/youtube-chatbot",
    packages=find_packages(),
    classifiers=[
        "Programming Language :: Python :: 3",
        "Programming Language :: Python :: 3.8",
        "Programming Language :: Python :: 3.9",
        "Programming Language :: Python :: 3.10",
        "Programming Language :: Python :: 3.11",
        "License :: OSI Approved :: MIT License",
        "Operating System :: OS Independent",
        "Development Status :: 4 - Beta",
        "Intended Audience :: Developers",
        "Intended Audience :: End Users/Desktop",
        "Topic :: Multimedia :: Video",
        "Topic :: Software Development :: Libraries :: Python Modules",
    ],
    python_requires=">=3.8",
    install_requires=requirements,
    extras_require={
        "dev": [
            "pytest>=7.0",
            "pytest-cov>=4.0",
            "black>=23.0",
            "flake8>=6.0",
            "mypy>=1.0",
            "pre-commit>=3.0",
        ],
        "streamlit": [
            "streamlit>=1.28.0",
        ],
    },
    entry_points={
        "console_scripts": [
            "youtube-chatbot=youtube_chatbot_complete:main",
        ],
    },
    include_package_data=True,
    keywords="youtube chatbot langchain openai qa question-answering",
    project_urls={
        "Bug Reports": "https://github.com/yourusername/youtube-chatbot/issues",
        "Documentation": "https://github.com/yourusername/youtube-chatbot/blob/main/README.md",
        "Source Code": "https://github.com/yourusername/youtube-chatbot",
    },
)
