"""
YouTube Transcript RAG Pipeline
Retrieves and answers questions about YouTube video transcripts using RAG architecture.
"""
 
import os
from dotenv import load_dotenv
from youtube_transcript_api import YouTubeTranscriptApi, TranscriptsDisabled
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain_openai import OpenAIEmbeddings, ChatOpenAI
from langchain_community.vectorstores import FAISS
from langchain_core.prompts import PromptTemplate
from langchain_core.runnables import RunnableParallel, RunnablePassthrough, RunnableLambda
from langchain_core.output_parsers import StrOutputParser
 
 
# Load environment variables from .env file
load_dotenv()
 
 
class YouTubeTranscriptRAG:
    """
    A Retrieval Augmented Generation (RAG) system for YouTube video transcripts.
    
    This class handles:
    - Fetching YouTube transcripts
    - Splitting text into chunks
    - Creating embeddings
    - Building a vector store
    - Retrieving relevant information
    - Generating answers using LLM
    """
    
    def __init__(self, model="gpt-4o-mini", temperature=0.2):
        """
        Initialize the RAG system with specified LLM model.
        
        Args:
            model (str): OpenAI model name. Default: "gpt-4o-mini"
            temperature (float): LLM temperature for randomness. Default: 0.2
        """
        self.llm = ChatOpenAI(model=model, temperature=temperature)
        self.vector_store = None
        self.retriever = None
        self.chain = None
        self._setup_chain()
    
    def _setup_chain(self):
        """Setup the RAG chain with prompt and parser."""
        prompt = PromptTemplate(
            template="""You are a helpful assistant.
Answer ONLY from the provided transcript context.
If the context is insufficient, say you don't know.
 
Context:
{context}
 
Question: {question}""",
            input_variables=['context', 'question']
        )
        
        def format_docs(retrieved_docs):
            """Format retrieved documents into context text."""
            return "\n\n".join(doc.page_content for doc in retrieved_docs)
        
        # Build the chain
        parallel_chain = RunnableParallel({
            'context': self.retriever | RunnableLambda(format_docs) if self.retriever else RunnablePassthrough(),
            'question': RunnablePassthrough()
        })
        
        parser = StrOutputParser()
        self.chain = parallel_chain | prompt | self.llm | parser
    
    def ingest_transcript(self, video_id, languages=["en"]):
        """
        Step 1a: Fetch and ingest YouTube transcript.
        
        Args:
            video_id (str): YouTube video ID (not full URL)
            languages (list): Preferred languages for transcript
            
        Returns:
            str: Raw transcript text
            
        Raises:
            TranscriptsDisabled: If captions are disabled for video
        """
        try:
            transcript_list = YouTubeTranscriptApi.get_transcript(
                video_id, 
                languages=languages
            )
            transcript = " ".join(chunk["text"] for chunk in transcript_list)
            print(f"✓ Successfully retrieved transcript ({len(transcript)} characters)")
            return transcript
            
        except TranscriptsDisabled:
            print("✗ Error: No captions available for this video.")
            raise
        except Exception as e:
            print(f"✗ Error fetching transcript: {e}")
            raise
    
    def split_text(self, transcript, chunk_size=1000, chunk_overlap=200):
        """
        Step 1b: Split transcript into overlapping chunks.
        
        Args:
            transcript (str): Raw transcript text
            chunk_size (int): Size of each chunk. Default: 1000
            chunk_overlap (int): Overlap between chunks. Default: 200
            
        Returns:
            list: List of document chunks
        """
        splitter = RecursiveCharacterTextSplitter(
            chunk_size=chunk_size,
            chunk_overlap=chunk_overlap
        )
        chunks = splitter.create_documents([transcript])
        print(f"✓ Created {len(chunks)} text chunks")
        return chunks
    
    def create_vector_store(self, chunks):
        """
        Step 1c & 1d: Generate embeddings and create vector store.
        
        Args:
            chunks (list): List of document chunks
            
        Returns:
            FAISS: Vector store with embeddings
        """
        embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
        self.vector_store = FAISS.from_documents(chunks, embeddings)
        print(f"✓ Created FAISS vector store with {len(chunks)} documents")
        
        # Setup retriever
        self.retriever = self.vector_store.as_retriever(
            search_type="similarity",
            search_kwargs={"k": 4}
        )
        
        # Rebuild chain with retriever
        self._setup_chain()
        return self.vector_store
    
    def retrieve_context(self, query, k=4):
        """
        Step 2: Retrieve relevant documents from vector store.
        
        Args:
            query (str): Search query
            k (int): Number of documents to retrieve. Default: 4
            
        Returns:
            list: List of relevant documents
        """
        if not self.retriever:
            raise ValueError("Vector store not initialized. Run create_vector_store first.")
        
        retrieved_docs = self.retriever.invoke(query)
        print(f"✓ Retrieved {len(retrieved_docs)} relevant documents")
        return retrieved_docs
    
    def answer_question(self, question):
        """
        Step 4: Answer question using RAG chain.
        
        Args:
            question (str): User question
            
        Returns:
            str: Answer based on transcript context
        """
        if not self.chain:
            raise ValueError("RAG chain not initialized.")
        
        answer = self.chain.invoke(question)
        return answer
 
 
def main():
    """Main function demonstrating the RAG pipeline."""
    
    print("=" * 60)
    print("YouTube Transcript RAG Pipeline")
    print("=" * 60)
    
    # Initialize RAG system
    rag = YouTubeTranscriptRAG(model="gpt-4o-mini", temperature=0.2)
    
    # Step 1: Ingest transcript
    video_id = "Gfr50f6ZBvo"  # YouTube video ID only
    transcript = rag.ingest_transcript(video_id, languages=["en"])
    print(f"\nFirst 200 characters: {transcript[:200]}...\n")
    
    # Step 2: Split text into chunks
    chunks = rag.split_text(transcript, chunk_size=1000, chunk_overlap=200)
    print(f"Sample chunk: {chunks[0].page_content[:200]}...\n")
    
    # Step 3: Create vector store
    rag.create_vector_store(chunks)
    
    # Step 4: Example retrieval
    sample_query = "What is deepmind"
    retrieved = rag.retrieve_context(sample_query, k=4)
    print(f"\nRetrieved documents for '{sample_query}':")
    for i, doc in enumerate(retrieved, 1):
        print(f"Doc {i}: {doc.page_content[:100]}...\n")
    
    # Step 5: Answer questions
    questions = [
        "is the topic of nuclear fusion discussed in this video? if yes then what was discussed",
        "who is Demis",
        "Can you summarize the video"
    ]
    
    print("\n" + "=" * 60)
    print("Answering Questions")
    print("=" * 60)
    
    for question in questions:
        print(f"\nQ: {question}")
        answer = rag.answer_question(question)
        print(f"A: {answer}\n")
 
 
if __name__ == "__main__":
    main()
